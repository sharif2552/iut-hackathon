{
  "name": "office-energy-monitor",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first Office Energy Monitor: real-time dashboard + Discord bot sharing one backend source of truth.",
  "workspaces": [
    "backend",
    "frontend",
    "discord-bot"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:bot": "npm run dev --workspace discord-bot",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "seed": "npm run seed --workspace backend"
  },
  "engines": {
    "node": ">=20"
  }
}
